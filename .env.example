# QuickFolio Environment Variables
# Copy this to .env and fill in your values

# REQUIRED — change this to a long random string in production
SECRET_KEY=quickfolio-super-secret-key-change-in-production-use-random-64-chars

# Runtime mode
APP_ENV=development

# Public base URL used for sitemap/canonical generation in production
SITE_URL=

# Force Secure cookies if you are always behind HTTPS
COOKIE_SECURE=0

# Password reset code expiry window (minutes)
PASSWORD_RESET_TTL_MINUTES=20

# Database path (auto-created)
DATABASE=instance/QuickFolio.db

# ----- OPTIONAL: Social OAuth -----
# GitHub OAuth  → https://github.com/settings/developers
# Callback URL (local): http://localhost:5000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth  → https://console.cloud.google.com
# Callback URL (local): http://localhost:5000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIn OAuth → https://www.linkedin.com/developers/apps
# Callback URL (local): http://localhost:5000/api/auth/callback/linkedin
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ----- OPTIONAL: Email (SMTP) -----
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=Ks6911843@gmail.com
